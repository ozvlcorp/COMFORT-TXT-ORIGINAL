# Telegram Bot Token (from @BotFather)
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MoySklad API Bearer Token
# Получить: МойСклад → Настройки → Пользователи → Ключи доступа
MOYSKLAD_TOKEN=your_moysklad_bearer_token_here

# Webhook server settings (публичный URL для приёма вебхуков от МойСклад)
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/moysklad/webhook
WEBHOOK_PORT=8080

# Secret to validate MoySklad webhook requests
WEBHOOK_SECRET=change_me_to_random_string

# SQLite database file path.
# ВАЖНО: в Docker должно указывать на смонтированный том (/data), иначе
# при пересборке контейнера БД исчезнет вместе с writable-слоем и
# зарегистрированные пользователи потеряются (нужно будет заново /start).
DB_PATH=/data/comfort_bot.db

# Telegram IDs of admins (comma-separated), can broadcast messages
ADMIN_IDS=123456789

# Время дневного отчёта (Asia/Tashkent), default 20:00
# DAILY_REPORT_HOUR=20
# DAILY_REPORT_MINUTE=0

# Company phone shown in bot description
COMPANY_PHONE=+998958220000

# IANA timezone — botning "hozir" va kalendarlari (momentlar MS qatoridagi raqamlar bilan)
APP_TIMEZONE=Asia/Tashkent

# 1 = har bir hujjat momenti uchun log (raw → saqlangan)
# MS_MOMENT_LOG=1

# MS moment offset siz kelsa: defaultda o‘zgartirilmaydi (none)
# O‘chirish: MOYSKLAD_MOMENT_NAIVE_SOURCE_TZ=none
# MOYSKLAD_MOMENT_NAIVE_SOURCE_TZ=Europe/Moscow

# MoySklad: otgruzka ro'yxati enrich parallelizm (1–16, default 6)
# MOYSKLAD_ENRICH_CONCURRENCY=6
# Webhook workerlar (kichik VPS: 2–3, default 3)
# WEBHOOK_WORKERS=3
